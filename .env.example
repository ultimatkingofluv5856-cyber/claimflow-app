# Supabase Configuration (Frontend)
# These keys are safe to expose - they are public/anon keys
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_key"

# NOTE: RESEND_API_KEY should NOT be in this file
# Instead, configure it as a Supabase Secret via:
# supabase secrets set RESEND_API_KEY="your_resend_api_key"
# The Edge Function will read it using Deno.env.get("RESEND_API_KEY")
